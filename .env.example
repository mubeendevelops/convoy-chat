# Server
PORT=8080
APP_ENV=development

# PostgreSQL (matches docker-compose.yml postgres service; host port 5433
# because 5432 is often already taken by a native/system Postgres install)
DATABASE_URL=postgres://convoy:convoy@localhost:5433/convoychat?sslmode=disable

# Redis (matches docker-compose.yml redis service)
REDIS_URL=redis://localhost:6379/0

# Auth
# HS256 signing secret, minimum 32 characters. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-32-plus-character-secret
# Access-token lifetime — short, since refresh tokens (Phase 3) now cover
# staying signed in; the client transparently refreshes on expiry.
JWT_TTL=15m

# CORS: comma-separated list of origins allowed to call the REST API and
# open the WebSocket connection.
CORS_ALLOWED_ORIGINS=http://localhost:3000
