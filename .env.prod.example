# Reference env for docker-compose.prod.yml. Copy to .env.prod (gitignored —
# never commit real secrets) and fill in real values before running the prod
# compose. Also the reference for which env vars each managed platform needs
# when NOT using this compose file directly (Render backend, Vercel
# frontend) — see DEPLOYMENT.md.
#
# DATABASE_URL and REDIS_URL are deliberately NOT set here: they're composed
# inside docker-compose.prod.yml itself from the POSTGRES_*/REDIS_PASSWORD
# values below (via compose's ${VAR} interpolation, service names as
# hostnames), so there's exactly one place each password lives — set them
# once here, not twice. Run compose with `--env-file .env.prod` so that
# interpolation actually resolves (see CLAUDE.md Commands).

# ---- Postgres (compose-managed container) ----------------------------------
POSTGRES_USER=convoy
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=convoychat

# ---- Redis (compose-managed container) --------------------------------------
REDIS_PASSWORD=change-me-strong-password

# ---- Backend ----------------------------------------------------------------
APP_ENV=production

# Host port the backend is published on (container port is always 8080).
API_PORT=8080

# HS256 signing secret, minimum 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-32-plus-character-secret
JWT_TTL=24h

# Comma-separated list of origins allowed to call the REST API / open the WS
# connection — set to your real frontend origin(s), e.g.
# https://convoychat.vercel.app. Also gates the WS Origin check (see
# CLAUDE.md's WebSocket event contract). No trailing slashes, scheme required.
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example
